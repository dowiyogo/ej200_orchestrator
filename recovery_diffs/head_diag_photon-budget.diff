+G4double DetectorConstruction::TopSiPMCenterX(G4int idx) {
+    if (idx < 0 || idx >= kNTopSiPMs) return 0.0;
+    if (idx < 35) return (-692.0 + 20.0 * idx) * mm;
+    return (12.0 + 20.0 * (idx - 35)) * mm;
